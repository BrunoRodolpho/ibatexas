{
  "name": "@ibatexas/domain",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "rm -rf dist && tsc --outDir dist",
    "lint": "tsc --noEmit",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "db:seed:tables": "tsx src/seed-tables.ts",
    "db:seed:homepage": "tsx src/seed-homepage.ts",
    "db:seed:delivery": "tsx src/seed-delivery.ts",
    "db:seed:orders": "tsx src/seed-orders.ts"
  },
  "dependencies": {
    "@ibatexas/types": "workspace:*",
    "@prisma/adapter-pg": "^7.6.0",
    "@prisma/client": "^7.6.0"
  },
  "devDependencies": {
    "prisma": "^7.6.0",
    "tsx": "^4.7.0",
    "typescript": "^5.9.0"
  }
}
