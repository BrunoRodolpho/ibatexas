// IbateXas custom domain schema.
// Lives in the `ibx_domain` PostgreSQL schema — separate namespace from Medusa.
//
// Run `ibx db migrate:domain` to apply migrations.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma-client"
}

datasource db {
  provider = "postgresql"
  schemas  = ["ibx_domain"]
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum TableLocation {
  indoor
  outdoor
  bar
  terrace

  @@schema("ibx_domain")
}

enum ReservationStatus {
  pending
  confirmed
  seated
  completed
  cancelled
  no_show

  @@schema("ibx_domain")
}

enum StaffRole {
  OWNER
  MANAGER
  ATTENDANT

  @@schema("ibx_domain")
}

/// Payment lifecycle status — mirrors the const in @ibatexas/types.
/// Terminal per-attempt: refunded, canceled, waived, payment_failed, payment_expired.
/// Retry/regeneration creates a NEW Payment row; the old one stays terminal.
enum PaymentStatus {
  awaiting_payment
  payment_pending
  payment_expired
  payment_failed
  cash_pending
  paid
  switching_method
  partially_refunded
  refunded
  disputed
  canceled   @map("pay_canceled") // disambiguate from OrderFulfillmentStatus.canceled
  waived

  @@schema("ibx_domain")
}

/// Order fulfillment lifecycle status — mirrors the const in @ibatexas/types.
/// Kept in sync via compile-time test (order-status-enum-sync.test.ts).
enum OrderFulfillmentStatus {
  pending
  confirmed
  preparing
  ready
  in_delivery
  delivered
  canceled

  @@schema("ibx_domain")
}

/// Actor who triggered an order state transition.
enum OrderActor {
  admin
  system
  system_backfill
  customer

  @@schema("ibx_domain")
}

// ─── Models ───────────────────────────────────────────────────────────────────

/// Physical table in the restaurant.
model Table {
  id         String        @id @default(cuid())
  number     String        @unique
  capacity   Int
  location   TableLocation
  accessible Boolean       @default(false)
  active     Boolean       @default(true)
  createdAt  DateTime      @default(now()) @map("created_at")
  updatedAt  DateTime      @updatedAt @map("updated_at")

  reservationTables ReservationTable[]

  @@map("tables")
  @@schema("ibx_domain")
}

/// A bookable time slot for the whole restaurant (not per-table).
/// maxCovers is the total seat count across all tables available in this slot.
/// reservedCovers is updated atomically when a reservation is created/cancelled.
model TimeSlot {
  id              String   @id @default(cuid())
  date            DateTime @db.Date
  // AUDIT-FIX: DL-F07 — Constrained to VarChar(5) to enforce 'HH:MM' format at DB level.
  // Application layer validates format before write; this annotation prevents oversized strings.
  startTime       String   @db.VarChar(5) // 'HH:MM' format, e.g. '19:30'
  durationMinutes Int      @default(90) @map("duration_minutes")
  maxCovers       Int      @map("max_covers")
  reservedCovers  Int      @default(0) @map("reserved_covers")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  reservations Reservation[]
  waitlist     Waitlist[]

  @@unique([date, startTime])
  @@index([date])
  @@map("time_slots")
  @@schema("ibx_domain")
}

/// A table reservation.
/// AUDIT-FIX: DL-F08 — Added FK relation from customerId to Customer.
model Reservation {
  id              String            @id @default(cuid())
  displayId       Int               @default(autoincrement()) @map("display_id")
  customerId      String            @map("customer_id")
  partySize       Int               @map("party_size")
  status          ReservationStatus @default(pending)
  // AUDIT-FIX: DL-F12 — Expected JSON shape is SpecialRequest[]:
  //   { type: 'birthday'|'anniversary'|'allergy_warning'|'highchair'|'window_seat'|'accessible'|'other',
  //     notes?: string }
  // Validated via Zod SpecialRequestSchema at application layer. Legacy seed data may contain
  // plain string[] — consumers must handle both shapes gracefully.
  specialRequests Json              @default("[]") @map("special_requests")
  // ISO 8601 strings for confirmationMessage building
  confirmedAt     DateTime?         @map("confirmed_at")
  checkedInAt     DateTime?         @map("checked_in_at")
  cancelledAt     DateTime?         @map("cancelled_at")
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")

  // AUDIT-FIX: DL-F08 — FK relation to Customer for referential integrity
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Restrict)

  // AUDIT-FIX: DL-F02 — Changed onDelete from Cascade to Restrict to prevent
  // silent deletion of reservations when a TimeSlot is removed.
  timeSlot   TimeSlot @relation(fields: [timeSlotId], references: [id], onDelete: Restrict)
  timeSlotId String   @map("time_slot_id")

  tables ReservationTable[]

  @@index([customerId])
  @@index([timeSlotId])
  @@index([status])
  @@map("reservations")
  @@schema("ibx_domain")
}

/// Join table: a reservation can span multiple physical tables for large parties.
model ReservationTable {
  reservation   Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  reservationId String      @map("reservation_id")
  table         Table       @relation(fields: [tableId], references: [id], onDelete: Restrict)
  tableId       String      @map("table_id")

  @@id([reservationId, tableId])
  @@map("reservation_tables")
  @@schema("ibx_domain")
}

/// Waitlist entry when a time slot is fully booked.
/// Position is derived (ORDER BY createdAt among entries for the same slot).
model Waitlist {
  id         String    @id @default(cuid())
  customerId String    @map("customer_id")
  partySize  Int       @map("party_size")
  notifiedAt DateTime? @map("notified_at")
  expiresAt  DateTime  @map("expires_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  // AUDIT-FIX: DL-F02 — Changed onDelete from Cascade to Restrict to prevent
  // silent deletion of waitlist entries when a TimeSlot is removed.
  timeSlot   TimeSlot @relation(fields: [timeSlotId], references: [id], onDelete: Restrict)
  timeSlotId String   @map("time_slot_id")

  @@unique([customerId, timeSlotId])
  @@index([customerId])
  @@index([timeSlotId])
  @@map("waitlist")
  @@schema("ibx_domain")
}

/// Product review submitted by an authenticated customer after delivery.
/// Stored here (not in Medusa) so it can be read without Medusa overhead.
model Review {
  id         String   @id @default(cuid())
  orderId    String   @map("order_id")    // Medusa order id
  // AUDIT-FIX: DL-F03 — productIds is DEPRECATED. Use productId instead.
  // Deprecation plan: (1) backfill migration sets product_id = product_ids[1] where null,
  // (2) stop writing to productIds in application code, (3) drop column in future migration.
  productIds String[] @map("product_ids") // DEPRECATED — use productId
  productId  String?  @map("product_id")  // primary product this review is for
  customerId String   @map("customer_id")
  rating     Int      // 1–5
  comment    String?
  channel    String   // 'web' | 'whatsapp'
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  customer Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)

  @@unique([orderId, customerId])
  @@index([customerId])
  @@index([orderId])
  @@index([rating])
  @@index([productId])
  @@map("reviews")
  @@schema("ibx_domain")
}

// ─── Staff & Auth ────────────────────────────────────────────────────────────

/// Restaurant staff member. Authenticated via Twilio Verify OTP (same as customers).
/// Role determines access level: OWNER > MANAGER > ATTENDANT.
model Staff {
  id        String    @id @default(cuid())
  phone     String    @unique
  name      String
  role      StaffRole @default(ATTENDANT)
  active    Boolean   @default(true)
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  @@index([phone])
  @@map("staff")
  @@schema("ibx_domain")
}

// ─── Customer & Auth ──────────────────────────────────────────────────────────

/// Twilio-verified customer profile. Phone is the primary identity.
model Customer {
  id             String    @id @default(cuid())
  phone          String    @unique
  name           String?
  email          String?
  cpf            String?   @db.VarChar(14) // format: 000.000.000-00
  medusaId       String?   @unique @map("medusa_id")
  source         String?                            /// Origin channel: 'web' | 'whatsapp'
  firstContactAt DateTime? @map("first_contact_at") /// Timestamp of first interaction
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  addresses        Address[]
  preferences      CustomerPreferences?
  reviews          Review[]
  orderItems       CustomerOrderItem[]
  orderProjections OrderProjection[]
  reservations     Reservation[]           // AUDIT-FIX: DL-F08 — inverse relation
  waitlists        Waitlist[]
  loyaltyAccount   LoyaltyAccount?
  conversations    Conversation[]

  @@index([phone])
  @@map("customers")
  @@schema("ibx_domain")
}

/// Delivery address for a customer.
model Address {
  id         String  @id @default(cuid())
  customerId String  @map("customer_id")
  street     String
  number     String
  complement String?
  district   String
  city       String
  state      String  @db.Char(2)
  cep        String  @db.Char(8)
  isDefault  Boolean @default(false) @map("is_default")

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@map("addresses")
  @@schema("ibx_domain")
}

/// Customer dietary preferences — one row per customer.
/// allergenExclusions must always be an explicit array (never inferred).
model CustomerPreferences {
  id                  String   @id @default(cuid())
  customerId          String   @unique @map("customer_id")
  dietaryRestrictions String[] @map("dietary_restrictions")
  allergenExclusions  String[] @map("allergen_exclusions")
  favoriteCategories  String[] @map("favorite_categories")
  updatedAt           DateTime @updatedAt @map("updated_at")

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@map("customer_preferences")
  @@schema("ibx_domain")
}

/// One row per product per order — powers personalized recommendations and co-purchase matrix.
/// Not deleted on order cancellation (needed for analytics).
model CustomerOrderItem {
  id               String   @id @default(cuid())
  // AUDIT-FIX: DL-F10 — Made nullable so SetNull preserves analytics data after customer deletion
  customerId       String?  @map("customer_id")
  medusaOrderId    String   @map("medusa_order_id")
  productId        String   @map("product_id")
  variantId        String   @map("variant_id")
  quantity         Int
  priceInCentavos  Int      @map("price_in_centavos")
  orderedAt        DateTime @map("ordered_at")

  // AUDIT-FIX: DL-F10 — Changed onDelete from Cascade to SetNull to preserve
  // analytics data (co-purchase matrix, recommendations) after customer deletion.
  customer Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)

  @@index([customerId, productId])
  @@index([medusaOrderId])
  @@index([customerId])
  @@map("customer_order_items")
  @@schema("ibx_domain")
}

// ─── Order Projection ────────────────────────────────────────────────────────

/// Projection (read model) of a Medusa order. Source of truth for fulfillment status.
/// Populated by order.placed + order.status_changed NATS subscribers.
/// Medusa is the write-side commerce backend; this table is the read-side authority.
model OrderProjection {
  id                  String                 @id                                // = Medusa order ID
  displayId           Int                    @map("display_id")
  customerId          String?                @map("customer_id")               // domain Customer.id
  customerEmail       String?                @map("customer_email")
  customerName        String?                @map("customer_name")
  customerPhone       String?                @map("customer_phone")
  fulfillmentStatus   OrderFulfillmentStatus @default(pending) @map("fulfillment_status")
  paymentStatus       String?                @map("payment_status")
  totalInCentavos     Int                    @default(0) @map("total_in_centavos")
  subtotalInCentavos  Int                    @default(0) @map("subtotal_in_centavos")
  shippingInCentavos  Int                    @default(0) @map("shipping_in_centavos")
  itemCount           Int                    @default(0) @map("item_count")
  itemsJson           Json?                  @map("items_json")                // OrderEventItem[]
  itemsSchemaVersion  Int                    @default(1) @map("items_schema_version")
  shippingAddressJson Json?                  @map("shipping_address_json")
  deliveryType        String?                @map("delivery_type")             // "delivery" | "pickup" | "dine_in"
  paymentMethod       String?                @map("payment_method")            // "cash" | "pix" | "card"
  tipInCentavos       Int                    @default(0) @map("tip_in_centavos")
  version             Int                    @default(1)                        // optimistic concurrency
  medusaCreatedAt     DateTime               @map("medusa_created_at")
  createdAt           DateTime               @default(now()) @map("created_at")
  updatedAt           DateTime               @updatedAt @map("updated_at")

  currentPaymentId    String?              @map("current_payment_id")

  customer      Customer?            @relation(fields: [customerId], references: [id], onDelete: SetNull)
  statusHistory OrderStatusHistory[]
  payments      Payment[]
  notes         OrderNote[]

  @@index([customerId])
  @@index([fulfillmentStatus])
  @@index([displayId])
  @@index([medusaCreatedAt])
  @@index([fulfillmentStatus, medusaCreatedAt(sort: Desc)])
  @@map("order_projections")
  @@schema("ibx_domain")
}

/// Append-only audit log of order fulfillment status transitions.
/// Each row represents one validated transition, with actor tracking.
model OrderStatusHistory {
  id              String                 @id @default(cuid())
  orderId         String                 @map("order_id")
  fromStatus      OrderFulfillmentStatus @map("from_status")
  toStatus        OrderFulfillmentStatus @map("to_status")
  actor           OrderActor             @default(system)
  actorId         String?                @map("actor_id")        // staff.id or customer.id
  reason          String?                                         // e.g. cancellation reason
  version         Int                                             // projection version AFTER this transition
  backfillBatchId String?                @map("backfill_batch_id") // set only by system_backfill
  createdAt       DateTime               @default(now()) @map("created_at")

  order OrderProjection @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId, createdAt])
  @@index([createdAt])
  @@map("order_status_history")
  @@schema("ibx_domain")
}

/// Append-only, immutable event log for ALL order domain events.
/// Observability + replay + debugging layer. Never mutated after insert.
model OrderEventLog {
  id              String   @id @default(cuid())
  orderId         String   @map("order_id")
  eventType       String   @map("event_type")
  idempotencyKey  String   @unique @map("idempotency_key")
  payload         Json
  timestamp       DateTime @map("timestamp")
  createdAt       DateTime @default(now()) @map("created_at")

  @@index([orderId, createdAt])
  @@index([orderId, eventType])
  @@index([eventType, timestamp])
  @@map("order_event_log")
  @@schema("ibx_domain")
}

// ─── Billing (Payment Lifecycle) ──────────────────────────────────────

/// Payment record for an order. ONE active (non-terminal) payment per order,
/// enforced by partial unique index in migration SQL.
/// Historical attempts are kept with terminal status for audit trail.
/// Retry/regeneration creates a new row; old one stays terminal.
model Payment {
  id                     String        @id @default(cuid())
  orderId                String        @map("order_id")
  method                 String        // "pix" | "card" | "cash"
  status                 PaymentStatus @default(awaiting_payment)
  amountInCentavos       Int           @map("amount_in_centavos")
  stripePaymentIntentId  String?       @unique @map("stripe_payment_intent_id")
  pixExpiresAt           DateTime?     @map("pix_expires_at")
  refundedAmountCentavos Int           @default(0) @map("refunded_amount_centavos")
  regenerationCount      Int           @default(0) @map("regeneration_count")
  idempotencyKey         String?       @unique @map("idempotency_key")
  lastStripeEventTs      DateTime?     @map("last_stripe_event_ts")
  version                Int           @default(1)
  createdAt              DateTime      @default(now()) @map("created_at")
  updatedAt              DateTime      @updatedAt @map("updated_at")

  order         OrderProjection        @relation(fields: [orderId], references: [id])
  statusHistory PaymentStatusHistory[]

  @@index([orderId])
  @@index([status])
  @@index([orderId, status])
  @@map("payments")
  @@schema("ibx_domain")
}

/// Append-only audit log of payment status transitions.
/// Mirrors OrderStatusHistory pattern for full observability.
model PaymentStatusHistory {
  id         String        @id @default(cuid())
  paymentId  String        @map("payment_id")
  fromStatus PaymentStatus @map("from_status")
  toStatus   PaymentStatus @map("to_status")
  actor      OrderActor    @default(system)
  actorId    String?       @map("actor_id")
  reason     String?
  version    Int
  createdAt  DateTime      @default(now()) @map("created_at")

  payment Payment @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  @@index([paymentId, createdAt])
  @@map("payment_status_history")
  @@schema("ibx_domain")
}

// ─── Order Notes ─────────────────────────────────────────────────────

/// Customer special instructions + admin/kitchen notes on an order.
model OrderNote {
  id         String     @id @default(cuid())
  orderId    String     @map("order_id")
  author     OrderActor
  authorId   String?    @map("author_id")
  content    String     @db.VarChar(500)
  isInternal Boolean    @default(false) @map("is_internal")
  createdAt  DateTime   @default(now()) @map("created_at")

  order OrderProjection @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId, createdAt])
  @@map("order_notes")
  @@schema("ibx_domain")
}

// ─── Loyalty ──────────────────────────────────────────────────────────────────

/// Punch-card loyalty account for a customer.
/// stamps: current punch count (resets to 0 after reward).
/// totalEarned: lifetime stamps earned (never decremented).
/// redeemed: number of rewards redeemed (incremented when stamp 10 is earned).
model LoyaltyAccount {
  id          String   @id @default(cuid())
  customerId  String   @unique @map("customer_id")
  customer    Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  stamps      Int      @default(0)
  totalEarned Int      @default(0) @map("total_earned")
  redeemed    Int      @default(0)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("loyalty_accounts")
  @@schema("ibx_domain")
}

// ─── Conversations ────────────────────────────────────────────────────────────

enum ConversationChannel {
  whatsapp
  web
  @@schema("ibx_domain")
}

enum MessageRole {
  user
  assistant
  system
  @@schema("ibx_domain")
}

model Conversation {
  id         String              @id @default(cuid())
  sessionId  String              @unique @map("session_id")
  customerId String?             @map("customer_id")
  channel    ConversationChannel
  startedAt  DateTime            @default(now()) @map("started_at")
  endedAt    DateTime?           @map("ended_at")
  createdAt  DateTime            @default(now()) @map("created_at")
  updatedAt  DateTime            @updatedAt @map("updated_at")

  customer Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  messages ConversationMessage[]

  @@index([customerId])
  @@index([channel])
  @@index([startedAt])
  @@map("conversations")
  @@schema("ibx_domain")
}

model ConversationMessage {
  id             String      @id @default(cuid())
  conversationId String      @map("conversation_id")
  role           MessageRole
  content        String
  metadata       Json?
  sentAt         DateTime    @default(now()) @map("sent_at")
  createdAt      DateTime    @default(now()) @map("created_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, sentAt])
  @@map("conversation_messages")
  @@schema("ibx_domain")
}

// ─── Delivery ─────────────────────────────────────────────────────────────────

/// Delivery zone defined by CEP prefix matching.
/// Optional centerLat/centerLng/radiusKm define a circular zone for GPS pin fallback.
model DeliveryZone {
  id                 String   @id @default(cuid())
  name               String
  cepPrefixes        String[] @map("cep_prefixes")
  feeInCentavos      Int      @map("fee_in_centavos")
  estimatedMinutes   Int      @map("estimated_minutes")
  active             Boolean  @default(true)
  centerLat          Decimal? @map("center_lat") @db.Decimal(9, 6)
  centerLng          Decimal? @map("center_lng") @db.Decimal(9, 6)
  radiusKm           Int?     @map("radius_km")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  @@map("delivery_zones")
  @@schema("ibx_domain")
}

// ─── Restaurant Schedule ────────────────────────────────────────────────────

model WeeklySchedule {
  id          String   @id @default(cuid())
  dayOfWeek   Int      @map("day_of_week") // 0=Sun, 1=Mon ... 6=Sat
  isOpen      Boolean  @default(true) @map("is_open")
  lunchStart  String?  @db.VarChar(5) @map("lunch_start")  // "11:00"
  lunchEnd    String?  @db.VarChar(5) @map("lunch_end")    // "15:00"
  dinnerStart String?  @db.VarChar(5) @map("dinner_start") // "18:00"
  dinnerEnd   String?  @db.VarChar(5) @map("dinner_end")   // "23:00"
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@unique([dayOfWeek])
  @@map("weekly_schedules")
  @@schema("ibx_domain")
}

model Holiday {
  id        String   @id @default(cuid())
  date      DateTime @unique @db.Date
  label     String   @db.VarChar(100)
  allDay    Boolean  @default(true) @map("all_day")
  startTime String?  @map("start_time") @db.VarChar(5) /// "HH:MM" — only when allDay=false
  endTime   String?  @map("end_time") @db.VarChar(5)   /// "HH:MM" — only when allDay=false
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("holidays")
  @@schema("ibx_domain")
}

/// Per-date schedule override. When present, this day uses custom hours
/// instead of the WeeklySchedule template. Holidays take precedence over overrides.
model ScheduleOverride {
  id        String   @id @default(cuid())
  date      DateTime @unique @db.Date
  isOpen    Boolean  @default(true) @map("is_open")
  blocks    Json     @default("[]") /// Array of { label: string, start: string, end: string }
  note      String?  @db.VarChar(200)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("schedule_overrides")
  @@schema("ibx_domain")
}
