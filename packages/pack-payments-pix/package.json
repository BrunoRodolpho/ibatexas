{
  "name": "@adjudicate/pack-payments-pix",
  "version": "0.1.0-experimental",
  "description": "PIX (Brazilian instant payment) charge lifecycle Pack for the Adjudicate kernel.",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc --outDir dist",
    "lint": "tsc --noEmit && eslint \"src/**/*.ts\"",
    "test": "vitest run"
  },
  "dependencies": {
    "@adjudicate/core": "workspace:*",
    "@adjudicate/runtime": "workspace:*"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.0.0",
    "@ibatexas/eslint-config": "workspace:*",
    "@vitest/coverage-v8": "^3.2.0",
    "eslint": "^9.0.0",
    "typescript": "^5.9.0",
    "vitest": "^3.2.0"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "keywords": [
    "adjudicate",
    "pack",
    "pix",
    "payments",
    "brazil",
    "intent-gated-execution"
  ]
}
