    "execa": "^8.0.1",
    "ora": "^8.0.1",
    "pg": "^8.11.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/pg": "^8.11.0",
    "tsx": "^4.0.0",
    "typescript": "^5.3.0",
    "vitest": "^1.6.0"
  }
}
