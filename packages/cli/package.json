{
  "name": "@ibatexas/cli",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "ibx — internal CLI for the IbateXas monorepo",
  "bin": {
    "ibx": "./dist/index.js"
  },
  "scripts": {
