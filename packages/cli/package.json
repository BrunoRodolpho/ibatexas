{
  "name": "@ibatexas/cli",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "ibx — internal CLI for the IbateXas monorepo",
  "bin": {
    "ibx": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc --outDir dist",
    "dev": "tsc --watch",
    "start": "tsx src/index.ts",
    "lint": "tsc --noEmit && eslint \"src/**/*.ts\"",
    "test": "vitest run"
  },
  "dependencies": {
    "@ibatexas/domain": "workspace:*",
    "@ibatexas/nats-client": "workspace:*",
    "@ibatexas/tools": "workspace:*",
    "@ibatexas/types": "workspace:*",
    "@inquirer/prompts": "^7.10.1",
    "chalk": "^5.6.2",
    "commander": "^13.1.0",
    "dotenv": "^16.6.1",
    "execa": "^9.6.1",
    "ora": "^9.3.0",
    "pg": "^8.20.0",
    "seedrandom": "^3.0.5",
    "uuid": "^10.0.0",
    "yaml": "^2.8.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.0.0",
    "@ibatexas/eslint-config": "workspace:*",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.11.0",
    "@types/seedrandom": "^3.0.8",
    "eslint": "^9.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.9.0",
    "vitest": "^3.2.0"
  }
}
