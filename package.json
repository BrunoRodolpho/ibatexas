{
  "name": "ibatexas",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "test": "turbo test",
    "db:migrate": "turbo db:migrate",
    "db:seed": "turbo db:seed",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\"",
    "audit:overrides": "tsx scripts/audit-overrides.ts",
    "check:overrides": "tsx scripts/check-overrides-change.ts",
    "upgrade:radar": "tsx scripts/upgrade-radar.ts"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^22.0.0",
    "@types/uuid": "^10.0.0",
    "@vitest/coverage-v8": "^3.2.0",
    "prettier": "^3.0.0",
    "tsx": "^4.21.0",
    "turbo": "^2.8.0",
    "typescript": "^5.9.0",
    "vitest": "^3.2.0"
  },
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@10.32.1",
  "pnpm": {
    "overrideNotes": {
      "hono, @hono/node-server, effect": "prisma security — remove when prisma >= 7.6 fixes upstream",
      "multer": "medusa transitive fix — remove when medusa upgrades multer",
      "fast-xml-parser": "aws-sdk/xml-builder security — remove when @aws-sdk updates",
      "@posthog/core": "posthog transitive fix — remove when posthog-js ships fixed version",
      "minimatch, rollup, glob": "vitest/vite toolchain — review on vite 6 upgrade",
      "@mikro-orm/core": "medusa transitive fix — GHSA-gwhv-j974-6fxm / GHSA-qpfv-44f3-qqx6 SQL injection",
      "path-to-regexp": "medusa>express transitive fix — GHSA-37ch-88jc-xwx2 ReDoS",
      "lodash": "medusa/prisma transitive fix — GHSA-r5fr-rjxr-66jc code injection via _.template",
      "picomatch": "eslint-config-next/vitest transitive fix — GHSA-c2c7-rcm5-vvqj ReDoS"
    },
    "overrides": {
      "hono": "4.12.8",
      "@hono/node-server": "1.19.11",
      "effect": "3.21.0",
      "multer": "2.1.1",
      "fast-xml-parser": "5.5.8",
      "@posthog/core": "1.24.1",
      "minimatch": "10.2.4",
      "rollup": "4.59.0",
      "glob": "13.0.6",
      "@mikro-orm/core": "6.6.10",
      "path-to-regexp": "0.1.13",
      "lodash": "4.18.1",
      "picomatch@<3": "2.3.2",
      "picomatch@>=4": "4.0.4"
    },
    "auditConfig": {
      "ignoreCves": [
        "CVE-2026-34950"
      ]
    },
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "@swc/core",
      "core-js",
      "esbuild",
      "msgpackr-extract",
      "prisma",
      "protobufjs",
      "sharp",
      "@parcel/watcher",
      "@medusajs/telemetry",
      "unrs-resolver"
    ]
  }
}
