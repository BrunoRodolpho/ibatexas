# WARNING: Change all default passwords for non-local environments  # AUDIT-FIX: INFRA-15

# ─── AI ───────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=                        # console.anthropic.com
OPENAI_API_KEY=                           # platform.openai.com (fallback LLM)

# Agent tuning (all have sensible defaults — override only if needed)
ANTHROPIC_MODEL=claude-sonnet-4-6           # LLM model for agent responses
AGENT_MAX_TURNS=10                        # max LLM conversation turns per session
AGENT_MAX_TOOL_RETRIES=3                  # max retries per individual tool call
AGENT_MAX_TOKENS=2048                     # max tokens per LLM response
AGENT_MAX_CONVERSATION_RETRIES=10          # max retries for conversation-level errors
AGENT_SESSION_TOKEN_BUDGET=100000         # AUDIT-FIX: AI-F03 — per-session cumulative token cap
AGENT_TOKEN_BUDGET_TTL=86400             # seconds before token budget resets (default 24h; use 600 for dev)
MACHINE_SNAPSHOT_TTL=86400                # XState machine snapshot TTL in Redis (seconds, default 24h)

# ─── App Environment ─────────────────────────────────────────────────────────
APP_ENV=development                       # development | staging | production — namespaces Redis keys

# ─── Payments ─────────────────────────────────────────────────────────────────
# All three keys from dashboard.stripe.com → API keys / Webhooks:
#   STRIPE_SECRET_KEY (sk_*)         — backend only. Full API access: create PaymentIntents, refunds, read customers.
#   STRIPE_WEBHOOK_SECRET (whsec_*)  — backend only. Verifies incoming webhook POSTs are genuinely from Stripe.
#   NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY (pk_*) — frontend (browser). Initializes Stripe.js for card form + payment confirmation. Safe to expose.
STRIPE_SECRET_KEY=                        # dashboard.stripe.com → API keys → Secret key
STRIPE_WEBHOOK_SECRET=                    # dashboard.stripe.com → Webhooks → Signing secret
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=       # dashboard.stripe.com → API keys → Publishable key
# Future: Pix checkout integration (Stripe Pix payment method ID, dashboard → payment methods)
STRIPE_PIX_PAYMENT_METHOD_ID=
PIX_EXPIRY_MINUTES=30                    # minutes before a pending PIX payment is expired (order preserved)
STALE_ORDER_THRESHOLD_HOURS=24           # hours before an unpaid pending order is auto-canceled
STALE_ORDER_DRY_RUN=false                # true = log but don't cancel stale orders

# ─── Database ─────────────────────────────────────────────────────────────────
# Local dev uses docker-compose Postgres on port 5433.
# Production uses Supabase managed Postgres — see docs/setup/supabase.md.
POSTGRES_USER=ibatexas                    # docker-compose postgres user
POSTGRES_PASSWORD=ibatexas               # docker-compose postgres password
POSTGRES_DB=ibatexas                     # docker-compose postgres database name
POSTGRES_PORT=5433                        # docker-compose postgres host port (5433 avoids conflict with local postgres)
# DATABASE_URL — Prisma query engine connection.
#   Local:      postgresql://ibatexas:ibatexas@localhost:5433/ibatexas
#   Supabase:   postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-sa-east-1.pooler.supabase.com:6543/postgres?connection_limit=10&pool_timeout=30&pgbouncer=true
DATABASE_URL=postgresql://ibatexas:ibatexas@localhost:5433/ibatexas
# DIRECT_DATABASE_URL — used by Prisma for migrations only (bypasses PgBouncer).
#   Local:      same as DATABASE_URL
#   Supabase:   postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-sa-east-1.pooler.supabase.com:5432/postgres
DIRECT_DATABASE_URL=postgresql://ibatexas:ibatexas@localhost:5433/ibatexas

# ─── Cache ────────────────────────────────────────────────────────────────────
# AUDIT-FIX: INFRA-12 — REDIS_URL must include the password when REDIS_PASSWORD is set.
# Local default: redis://:localdev@localhost:6379
# Production example: redis://:YOUR_STRONG_PASSWORD@redis-host:6379
REDIS_PASSWORD=localdev                   # AUDIT-FIX: INFRA-12 — Redis requirepass (change for non-local envs)
REDIS_URL=redis://:localdev@localhost:6379
REDIS_CB_FAILURE_THRESHOLD=5                 # circuit breaker: failures before opening (default 5)
REDIS_CB_RESET_TIMEOUT_MS=30000              # circuit breaker: reset timeout in ms (default 30s)

# ─── Search ───────────────────────────────────────────────────────────────────
TYPESENSE_HOST=localhost
TYPESENSE_PORT=8108
TYPESENSE_API_KEY=ibatexas-local-key
TYPESENSE_PROTOCOL=http                        # http (dev) or https (prod)
TYPESENSE_TIMEOUT_SECONDS=10
TYPESENSE_COLLECTION_NAME=products             # allows test isolation & multi-tenant deployments

# ─── Embeddings & RAG ──────────────────────────────────────────────────────────
EMBEDDING_MODEL=text-embedding-3-small                # (was CLAUDE_EMBEDDING_MODEL — old name still works as fallback)
OPENAI_BASE_URL=https://api.openai.com/v1     # override for proxy / Azure OpenAI / local LLM
EMBEDDING_DIMENSION=1536                       # 1536 = text-embedding-3-small; 3072 = text-embedding-3-large
EMBEDDINGS_CACHE_TTL_SECONDS=2592000     # 30 days; product embeddings cached in Redis
QUERY_CACHE_TTL_SECONDS=3600             # 1 hour; static query cache TTL
QUERY_CACHE_DYNAMIC_TTL_SECONDS=600      # 10 min; TTL for availability-sensitive queries
QUERY_CACHE_EXACT_TTL_SECONDS=300        # 5 min; L0 exact query cache TTL
QUERY_LOG_TTL_SECONDS=604800             # 7 days; query log retention in Redis

# ─── Restaurant Configuration ─────────────────────────────────────────────────
RESTAURANT_TIMEZONE=America/Sao_Paulo
# Schedule hours below are SEED VALUES — used only to populate the DB on first startup.
# After that, hours are managed via Admin UI → Horários. These env vars become fallbacks only.
RESTAURANT_LUNCH_START_HOUR=11
RESTAURANT_LUNCH_END_HOUR=15
RESTAURANT_DINNER_START_HOUR=18
RESTAURANT_DINNER_END_HOUR=23
RESTAURANT_PHONE=
RESTAURANT_SITE_URL=https://ibatexas.com.br
RESTAURANT_ADDRESS=                          # Physical address for WhatsApp bot (e.g., "Rua Exemplo 123, Ibaté - SP")
RESTAURANT_LAT=                              # restaurant latitude (weather-based demand prediction)
RESTAURANT_LNG=                              # restaurant longitude (weather-based demand prediction)
HESITATION_NUDGE_DELAY_MS=45000            # ms delay before sending R$15 credit nudge to new customers (default 45s)
NO_SHOW_GRACE_MINUTES=15                  # minutes after slot start before marking as no-show

# ─── PONR (Point of No Return) ──────────────────────────────────────────────
PONR_DEFAULT_AMEND_MINUTES=5                 # default amend window per product (minutes after order placed)
PONR_DEFAULT_CANCEL_MINUTES=5                # default cancel window per product (minutes after order placed)
PONR_DAY_OVERRIDES={}                        # JSON: per-day-of-week overrides, e.g. {"saturday":{"amendMinutes":15,"cancelMinutes":15},"monday":{"amendMinutes":0,"cancelMinutes":0}}

# ─── Messaging ────────────────────────────────────────────────────────────────
NATS_URL=nats://localhost:4222


# ─── Server ──────────────────────────────────────────────────────────────────
TRUST_PROXY=true                          # AUDIT-FIX: SEC-F13 — Set to true when behind a reverse proxy (ALB, nginx, Cloudflare)

# ─── Observability ────────────────────────────────────────────────────────────
SENTRY_DSN=                               # sentry.io
SENTRY_ENVIRONMENT=                       # development | staging | production (defaults to APP_ENV)
NEXT_PUBLIC_SENTRY_DSN=                   # same DSN for Next.js apps (client-side)
LOG_LEVEL=info                            # pino log level: trace | debug | info | warn | error | fatal
ENABLE_SWAGGER=true                       # set to "false" to disable /docs endpoint
NEXT_PUBLIC_POSTHOG_KEY=                  # us.posthog.com
NEXT_PUBLIC_POSTHOG_HOST=https://us.posthog.com

# ─── WhatsApp + Auth (Twilio) — Customer ─────────────────────────────────────
TWILIO_ACCOUNT_SID=                       # console.twilio.com — customer account
TWILIO_AUTH_TOKEN=                        # console.twilio.com — customer account
TWILIO_VERIFY_SID=                        # console.twilio.com → Verify → create service → Service SID
TWILIO_OTP_CHANNEL=sms                    # sms (default) or whatsapp (requires approved WhatsApp Business sender on Verify service)
TWILIO_WHATSAPP_NUMBER=                   # e.g. whatsapp:+14155238886 (sandbox or approved number)
TWILIO_WEBHOOK_URL=                       # Full public URL for WhatsApp webhook signature verification (e.g. https://bot.ibatexas.com.br/api/webhooks/whatsapp)

# ─── Staff/Admin Twilio (separate account) ────────────────────────────────────
# Falls back to TWILIO_* vars above if not set
TWILIO_STAFF_ACCOUNT_SID=                 # console.twilio.com — staff/admin account
TWILIO_STAFF_AUTH_TOKEN=                  # console.twilio.com — staff/admin account
TWILIO_STAFF_VERIFY_SID=                  # console.twilio.com → Verify → create service → Service SID (staff)
TWILIO_STAFF_OTP_CHANNEL=sms              # sms or whatsapp for staff OTP
NGROK_DOMAIN=                             # ngrok static domain for ibx dev start --with-tunnel (e.g. your-domain.ngrok-free.app)
STAFF_NOTIFICATION_PHONE=                 # Staff WhatsApp number for handoff notifications (e.g. whatsapp:+5511999990000)
STAFF_ALERT_PHONE=                        # Staff WhatsApp number for high-value cart alerts (plain number, e.g. +5511999990000)

# ─── PIX Payment ─────────────────────────────────────────────────────────────
PIX_FALLBACK_EMAIL=pedido@ibatexas.com.br  # Fallback email for Stripe PIX billing_details (WhatsApp users don't have email)
PIX_FALLBACK_TAX_ID=                        # Restaurant CNPJ for Stripe PIX billing_details (e.g. 12.345.678/0001-90). Required if Stripe account is US-based.
PIX_EXPIRY_SECONDS=3600                     # PIX QR code expiry in seconds (default 1h, max 3 days = 259200)

# ─── Session Security ────────────────────────────────────────────────────────
SESSION_HMAC_SECRET=change-me-in-production  # HMAC-SHA256 secret for signed session tokens — openssl rand -base64 32

# ─── Admin API ────────────────────────────────────────────────────────────────
ADMIN_API_KEY=                            # API key for admin routes — openssl rand -base64 32 (server-side only, used by apps/admin proxy route)

# ─── Medusa Admin Credentials ────────────────────────────────────────────────
# These also power server-side admin API auth: packages/tools/src/medusa/client.ts
# obtains a Bearer JWT via /auth/user/emailpass and caches it. No sk_ secret key
# needed — Medusa v2 admin middleware doesn't accept Basic auth. The publishable
# key for /store/* is auto-resolved at runtime from /admin/api-keys on first use,
# so it never needs to live in .env either.
MEDUSA_ADMIN_EMAIL=admin@ibatexas.com.br  # Medusa admin dashboard login email
MEDUSA_ADMIN_PASSWORD=                    # Medusa admin dashboard login password — min 8 chars

# ─── Medusa Secrets ───────────────────────────────────────────────────────────
JWT_SECRET=                               # min 32 chars — openssl rand -base64 32
COOKIE_SECRET=                            # min 32 chars — openssl rand -base64 32
# AUDIT-FIX: SEC-F11 — CORS_ORIGIN must include both web and admin origins, comma-separated
# (e.g., http://localhost:3000,http://localhost:3002 for dev; https://ibatexas.com.br,https://admin.ibatexas.com.br for prod)
CORS_ORIGIN=http://localhost:3000,http://localhost:3002
STORE_CORS=http://localhost:3000          # storefront origin (comma-separated for multiple)
ADMIN_CORS=http://localhost:9000          # Medusa admin origin
AUTH_CORS=http://localhost:3000,http://localhost:9000  # auth endpoints CORS
MEDUSA_WORKER_MODE=shared                 # shared | worker | server

# ─── App URLs ─────────────────────────────────────────────────────────────────
# NEXT_PUBLIC_* URLs are inlined into the client bundle at Next.js build time
# AND used by next.config.mjs to build the CSP connect-src directive. In
# deployed envs (dev/staging/prod) they must point at the Caddy-fronted HTTPS
# origins (e.g. https://api.ibatexas.com.br) — set via CI build-args and
# re-injected into the runtime .env by the EC2 bootstrap script.
APP_BASE_URL=http://localhost:3000              # REQUIRED — public app URL (used for review prompt links, notifications)
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_APP_URL=http://localhost:3000
MEDUSA_BACKEND_URL=http://localhost:9000
MEDUSA_URL=http://localhost:9000          # alias used by catalog routes (same as MEDUSA_BACKEND_URL)
NEXT_PUBLIC_MEDUSA_BACKEND_URL=http://localhost:9000  # Medusa admin URL, accessible from browser
WEB_URL=                                  # REQUIRED in production — public URL of the Next.js app (e.g. https://ibatexas.com.br)

# ─── Public Business Info (Footer/Contact) ───────────────────────────────────
NEXT_PUBLIC_PHONE=(17) 3341-5300
NEXT_PUBLIC_ADDRESS=Ibaté, SP
NEXT_PUBLIC_HOURS_WEEKDAY=11h - 23h
NEXT_PUBLIC_HOURS_SATURDAY=11h - 23h30
NEXT_PUBLIC_HOURS_SUNDAY=11h - 23h
NEXT_PUBLIC_INSTAGRAM_URL=               # e.g. https://instagram.com/ibatexas
NEXT_PUBLIC_FACEBOOK_URL=                # e.g. https://facebook.com/ibatexas
NEXT_PUBLIC_WHATSAPP_URL=                # e.g. https://wa.me/5517999999999

# ─── E2E Testing (Playwright) ───────────────────────────────────────────────
PLAYWRIGHT_BASE_URL=http://localhost:3000  # storefront URL for Playwright web tests
PLAYWRIGHT_API_URL=http://localhost:3001   # API URL for Playwright API tests
