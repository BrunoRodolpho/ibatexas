# ─── AI ───────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=                        # console.anthropic.com
OPENAI_API_KEY=                           # platform.openai.com (fallback LLM)

# ─── App Environment ─────────────────────────────────────────────────────────
APP_ENV=development                       # development | staging | production — namespaces Redis keys

# ─── Payments ─────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=                        # dashboard.stripe.com
STRIPE_WEBHOOK_SECRET=                    # dashboard.stripe.com → webhooks
# Future: Pix checkout integration (Stripe Pix payment method ID, dashboard → payment methods)
STRIPE_PIX_PAYMENT_METHOD_ID=

# ─── Database ─────────────────────────────────────────────────────────────────
POSTGRES_USER=ibatexas                    # docker-compose postgres user
POSTGRES_PASSWORD=ibatexas               # docker-compose postgres password
POSTGRES_DB=ibatexas                     # docker-compose postgres database name
POSTGRES_PORT=5433                        # docker-compose postgres host port (5433 avoids conflict with local postgres)
DATABASE_URL=postgresql://ibatexas:ibatexas@localhost:5433/ibatexas
DIRECT_DATABASE_URL=postgresql://ibatexas:ibatexas@localhost:5433/ibatexas

# ─── Cache ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Search ───────────────────────────────────────────────────────────────────
TYPESENSE_HOST=localhost
TYPESENSE_PORT=8108
TYPESENSE_API_KEY=ibatexas-local-key
TYPESENSE_PROTOCOL=http                        # http (dev) or https (prod)
TYPESENSE_TIMEOUT_SECONDS=10
TYPESENSE_COLLECTION_NAME=products             # allows test isolation & multi-tenant deployments

# ─── Embeddings & RAG ──────────────────────────────────────────────────────────
EMBEDDING_MODEL=text-embedding-3-small                # (was CLAUDE_EMBEDDING_MODEL — old name still works as fallback)
OPENAI_BASE_URL=https://api.openai.com/v1     # override for proxy / Azure OpenAI / local LLM
EMBEDDING_DIMENSION=1536                       # 1536 = text-embedding-3-small; 3072 = text-embedding-3-large
EMBEDDINGS_CACHE_TTL_SECONDS=2592000     # 30 days; product embeddings cached in Redis
QUERY_CACHE_TTL_SECONDS=3600             # 1 hour; static query cache TTL
QUERY_CACHE_DYNAMIC_TTL_SECONDS=600      # 10 min; TTL for availability-sensitive queries
QUERY_CACHE_EXACT_TTL_SECONDS=300        # 5 min; L0 exact query cache TTL
QUERY_LOG_TTL_SECONDS=604800             # 7 days; query log retention in Redis

# ─── Restaurant Configuration ─────────────────────────────────────────────────
RESTAURANT_TIMEZONE=America/Sao_Paulo
RESTAURANT_LUNCH_START_HOUR=11
RESTAURANT_LUNCH_END_HOUR=15
RESTAURANT_DINNER_START_HOUR=18
RESTAURANT_DINNER_END_HOUR=23

# ─── Messaging ────────────────────────────────────────────────────────────────
NATS_URL=nats://localhost:4222


# ─── Observability ────────────────────────────────────────────────────────────
SENTRY_DSN=                               # sentry.io
NEXT_PUBLIC_POSTHOG_KEY=                  # app.posthog.com
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# ─── WhatsApp + Auth (Twilio) ─────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=                       # console.twilio.com
TWILIO_AUTH_TOKEN=                        # console.twilio.com
TWILIO_VERIFY_SID=                        # console.twilio.com → Verify → create service → Service SID
TWILIO_OTP_CHANNEL=sms                    # sms (default) or whatsapp (requires approved WhatsApp Business sender on Verify service)
TWILIO_WHATSAPP_NUMBER=                   # e.g. whatsapp:+14155238886 (sandbox or approved number)
TWILIO_WEBHOOK_URL=                       # Full public URL for WhatsApp webhook signature verification (e.g. https://bot.ibatexas.com.br/api/webhooks/whatsapp)

# ─── Admin API ────────────────────────────────────────────────────────────────
ADMIN_API_KEY=                            # API key for admin routes — openssl rand -base64 32
NEXT_PUBLIC_ADMIN_API_KEY=                # Same as ADMIN_API_KEY — exposed to admin frontend for x-admin-key header (AUDIT-FIX: SEC-F01)

# ─── Medusa Secrets ───────────────────────────────────────────────────────────
JWT_SECRET=                               # min 32 chars — openssl rand -base64 32
COOKIE_SECRET=                            # min 32 chars — openssl rand -base64 32
# AUDIT-FIX: SEC-F11 — CORS_ORIGIN must include both web and admin origins, comma-separated
# (e.g., http://localhost:3000,http://localhost:3002 for dev; https://ibatexas.com.br,https://admin.ibatexas.com.br for prod)
CORS_ORIGIN=http://localhost:3000,http://localhost:3002
STORE_CORS=http://localhost:3000          # storefront origin (comma-separated for multiple)
ADMIN_CORS=http://localhost:9000          # Medusa admin origin
AUTH_CORS=http://localhost:3000,http://localhost:9000  # auth endpoints CORS
MEDUSA_WORKER_MODE=shared                 # shared | worker | server

# ─── App URLs ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_APP_URL=http://localhost:3000
MEDUSA_BACKEND_URL=http://localhost:9000
MEDUSA_URL=http://localhost:9000          # alias used by catalog routes (same as MEDUSA_BACKEND_URL)
NEXT_PUBLIC_MEDUSA_BACKEND_URL=http://localhost:9000  # Medusa admin URL, accessible from browser
MEDUSA_PUBLISHABLE_KEY=                  # Medusa store publishable key (Medusa Admin → Settings → API Keys)
WEB_URL=                                  # REQUIRED in production — public URL of the Next.js app (e.g. https://ibatexas.com.br)

# ─── Public Business Info (Footer/Contact) ───────────────────────────────────
NEXT_PUBLIC_PHONE=(17) 3341-5300
NEXT_PUBLIC_ADDRESS=Ibaté, SP
NEXT_PUBLIC_HOURS_WEEKDAY=11h - 23h
NEXT_PUBLIC_HOURS_SATURDAY=11h - 23h30
NEXT_PUBLIC_HOURS_SUNDAY=11h - 23h
NEXT_PUBLIC_INSTAGRAM_URL=               # e.g. https://instagram.com/ibatexas
NEXT_PUBLIC_FACEBOOK_URL=                # e.g. https://facebook.com/ibatexas
NEXT_PUBLIC_WHATSAPP_URL=                # e.g. https://wa.me/5517999999999
