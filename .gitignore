# Dependencies
node_modules/
.pnpm-store/

# Build outputs
dist/
.next/
.turbo/

# Test coverage reports
coverage/

# Playwright
tests/e2e/.results/
playwright-report/
test-results/

# Environment variables — never commit these
.env
.env.local
.env.*.local
secrets.env

# Terraform state — managed remotely
*.tfstate
*.tfstate.*
.terraform/
*.tfplan

# OS
.DS_Store
Thumbs.db

# Logs
*.log
npm-debug.log*
pnpm-debug.log*

# Editor
.vscode/
.idea/
*.swp
*.swo

# Claude Code local session files
.claude/

# ibx CLI runtime files
.ibx-dev.pids
.ibx/

# Next.js auto-generated type refs — rewrites between `.next/dev/types`
# (from `next dev`) and `.next/types` (from `next build`) so tracking
# them just produces churn. Header in the file itself says "should not
# be edited".
apps/*/next-env.d.ts

# Medusa auto-generated types
apps/commerce/.medusa/types/query-entry-points.d.ts

# Medusa admin file uploads
apps/commerce/static/
infra/terraform/environments/dev/tfplan
