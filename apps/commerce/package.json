{
  "name": "@ibatexas/commerce",
  "version": "0.0.1",
  "private": true,
  "//build": "build runs tsc --noEmit for CI type-checking; use build:medusa for actual Medusa deployment builds",
  "scripts": {
    "dev": "medusa develop",
    "build": "tsc --noEmit",
    "build:medusa": "medusa build",
    "start": "medusa start",
    "db:migrate": "medusa db:migrate",
    "db:seed": "medusa exec src/seed.ts",
    "db:setup": "medusa db:setup",
    "test": "vitest run",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@ibatexas/nats-client": "workspace:*",
    "@ibatexas/tools": "workspace:*",
    "@ibatexas/types": "workspace:*",
    "@medusajs/admin-sdk": "2.13.1",
    "@medusajs/admin-shared": "^2.13.1",
    "@medusajs/dashboard": "^2.13.1",
    "@medusajs/draft-order": "^2.13.1",
    "@medusajs/framework": "^2.13.1",
    "@medusajs/medusa": "^2.13.1",
    "@medusajs/utils": "^2.13.1",
    "@medusajs/workflows-sdk": "^2.13.1"
  },
  "devDependencies": {
    "@medusajs/cli": "^2.13.1",
    "ts-node": "^10.9.0",
    "typescript": "^5.3.0"
  }
}
